# Production backend API origin deployed on the VPS.
# Do not include /api/v1; the client appends it automatically.
# Leave empty for local development so Vite uses the same-origin /api proxy.
VITE_API_BASE_URL=https://api.your-domain.com

# Local development only. Used by vite.config.ts when VITE_API_BASE_URL is empty.
VITE_DEV_API_TARGET=http://localhost:8080

# Leave empty when the admin app is deployed at the Vercel project root.
VITE_ADMIN_PATH=
